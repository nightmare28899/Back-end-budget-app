generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BillingCycle {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
}

enum InstallmentFrequency {
  MONTHLY
}

enum SavingsTransactionType {
  DEPOSIT
  WITHDRAW
}

enum DevicePlatform {
  ANDROID
  IOS
}

model User {
  id                   String          @id @default(uuid())
  email                String          @unique
  password             String
  name                 String
  role                 String          @default("user")
  avatarUrl            String?
  dailyBudget          Decimal         @default(0) @db.Decimal(10, 2)
  budgetAmount         Decimal         @default(0) @db.Decimal(10, 2)
  budgetPeriod         String          @default("daily")
  budgetPeriodStart    DateTime?
  budgetPeriodEnd      DateTime?
  currency             String          @default("MXN")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  isActive             Boolean         @default(true)
  isPremium            Boolean         @default(false)
  weeklyReportEnabled  Boolean         @default(true) @map("weekly_report_enabled")
  monthlyReportEnabled Boolean         @default(false) @map("monthly_report_enabled")
  termsAcceptedAt      DateTime?       @map("terms_accepted_at")
  termsVersion         String?         @map("terms_version")
  deletedAt            DateTime?       @map("deleted_at")
  categories           Category[]
  creditCards          CreditCard[]
  expenses             Expense[]
  incomes              Income[]
  subscriptions        Subscription[]
  savingsGoals         SavingsGoal[]
  deviceTokens         DeviceToken[]
  authSessions         AuthSession[]
  reportHistory        ReportHistory[]

  @@map("users")
}

model AuthSession {
  id                    String    @id @default(uuid())
  userId                String
  currentRefreshTokenId String    @map("current_refresh_token_id")
  revokedAt             DateTime? @map("revoked_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
  @@map("auth_sessions")
}

model ReportHistory {
  id            String   @id @default(uuid())
  periodType    String   @map("period_type")
  source        String   @default("manual")
  referenceDate DateTime @map("reference_date")
  reportStart   DateTime @map("report_start")
  reportEnd     DateTime @map("report_end")
  snapshot      Json
  userId        String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, periodType, referenceDate])
  @@map("report_history")
}

model CreditCard {
  id            String         @id @default(uuid())
  name          String
  bank          String
  brand         String
  last4         String
  color         String?
  creditLimit   Decimal?       @db.Decimal(10, 2)
  closingDay    Int?
  paymentDueDay Int?
  isActive      Boolean        @default(true)
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  expenses      Expense[]
  subscriptions Subscription[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, name])
  @@map("credit_cards")
}

model Category {
  id           String    @id @default(uuid())
  name         String
  icon         String?
  color        String?
  budgetAmount Decimal?  @map("budget_amount") @db.Decimal(10, 2)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@unique([userId, name])
  @@map("categories")
}

model Expense {
  id                          String                @id @default(uuid())
  title                       String
  cost                        Decimal               @db.Decimal(10, 2)
  currency                    String                @default("MXN")
  paymentMethod               PaymentMethod         @default(CASH)
  creditCardId                String?
  isSubscription              Boolean               @default(false)
  subscriptionId              String?
  isInstallment               Boolean               @default(false)
  installmentGroupId          String?
  installmentCount            Int?
  installmentIndex            Int?
  installmentTotalAmount      Decimal?              @db.Decimal(10, 2)
  installmentFrequency        InstallmentFrequency?
  installmentPurchaseDate     DateTime?
  installmentFirstPaymentDate DateTime?
  imageUrl                    String?
  note                        String?
  date                        DateTime              @default(now())
  categoryId                  String?
  userId                      String
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  category                    Category?             @relation(fields: [categoryId], references: [id])
  creditCard                  CreditCard?           @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  subscription                Subscription?         @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user                        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([userId, isSubscription, date])
  @@index([userId, isInstallment, date])
  @@index([creditCardId])
  @@index([subscriptionId])
  @@index([installmentGroupId])
  @@map("expenses")
}

model Income {
  id        String   @id @default(uuid())
  title     String
  amount    Decimal  @db.Decimal(10, 2)
  currency  String   @default("MXN")
  note      String?
  date      DateTime @default(now())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("incomes")
}

model Subscription {
  id                  String        @id @default(uuid())
  name                String
  cost                Decimal       @db.Decimal(10, 2)
  paymentMethod       PaymentMethod @default(CREDIT_CARD)
  creditCardId        String?
  currency            String        @default("MXN")
  billingCycle        BillingCycle  @default(MONTHLY)
  nextPaymentDate     DateTime
  reminderDays        Int           @default(3)
  lastReminderSentFor DateTime?
  isActive            Boolean       @default(true)
  logoUrl             String?
  hexColor            String?
  userId              String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  creditCard          CreditCard?   @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  expenses            Expense[]
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, nextPaymentDate])
  @@index([userId, isActive])
  @@index([creditCardId])
  @@map("subscriptions")
}

model DeviceToken {
  id         String         @id @default(uuid())
  token      String         @unique
  platform   DevicePlatform
  userId     String
  lastSeenAt DateTime       @default(now())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model SavingsGoal {
  id            String               @id @default(uuid())
  title         String
  targetAmount  Decimal              @db.Decimal(10, 2)
  currentAmount Decimal              @default(0) @db.Decimal(10, 2)
  targetDate    DateTime?
  icon          String?
  color         String?
  userId        String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  SavingsTransaction[]

  @@index([userId, createdAt])
  @@map("savings_goals")
}

model SavingsTransaction {
  id        String                 @id @default(uuid())
  amount    Decimal                @db.Decimal(10, 2)
  type      SavingsTransactionType @default(DEPOSIT)
  goalId    String
  createdAt DateTime               @default(now())
  goal      SavingsGoal            @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, createdAt])
  @@map("savings_transactions")
}
