# App
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/budgetapp?schema=public

# JWT
JWT_SECRET=change-me
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRATION=7d
AUTH_SESSION_RETENTION_DAYS=30

# API security
CORS_ORIGIN=http://localhost:3000
API_BODY_LIMIT=1mb
SWAGGER_USERNAME=change-me
SWAGGER_PASSWORD=change-me

# Firebase Admin SDK for push notifications
# Prefer a local JSON path in development
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-adminsdk.json
# Or provide the raw JSON / discrete values in environments where files are not practical
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"..."}
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# MinIO / S3-compatible storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=app-uploads
MINIO_REGION=us-east-1
MINIO_FORCE_PATH_STYLE=true
MINIO_OPERATION_TIMEOUT_MS=15000

# MinIO server (docker-compose service)
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
